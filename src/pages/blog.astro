---
import BaseLayout from '@/layouts/BaseLayout'
import ListCategories from '@/components/ListCategories'
import ListPosts from '@/components/ListPosts'
import { getPosts } from '@/utils'

const posts = await getPosts()
---

<BaseLayout title='Blog'>
	<section
		class='relative overflow-hidden rounded-2xl bg-cover bg-center min-h-[360px] md:min-h-[440px] flex items-center justify-center'
		style="background-image: url('/images/head_for_code_cover.jpeg');"
	>
		<div class='absolute inset-0 bg-black/50'></div>
		<div class='relative z-10 p-6 md:p-12 text-center text-white'>
			<h1 class='text-4xl md:text-6xl font-bold leading-tight'>Blog</h1>
			<p class='mt-3 text-base md:text-lg text-white/90'>
				Thoughts, tutorials and updates from HeadForCode
			</p>
		</div>
	</section>

	<ListCategories />

	<div>
		<h2 class='text-lg font-medium tracking-wide text-end'>Latest Posts</h2>
		<ListPosts FirstBig={true} posts={posts} />
	</div>
</BaseLayout>
