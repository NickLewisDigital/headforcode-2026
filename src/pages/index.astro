---
import ListCategories from '@/components/ListCategories'
import ListPosts from '@/components/ListPosts'
import TitlePage from '@/components/TitlePage'
import ButtondownSubscription from '@/components/ButtondownSubscription'
import BaseLayout from '@/layouts/BaseLayout'
import { getPosts } from '@/utils'
import { siteConfig } from '@/site-config'

const MAX_POSTS = 5 // max number of posts to show on the home page
const posts = await getPosts(MAX_POSTS)
---

<BaseLayout title='Home'>
	<section
		class='relative overflow-hidden rounded-2xl bg-cover bg-center min-h-[360px] md:min-h-[440px] flex items-center'
		style="background-image: url('/images/head_for_code_cover.jpeg');"
	>
		<div class='absolute inset-0 bg-black/50'></div>
		<div class='relative z-10 p-6 md:p-12 max-w-3xl text-white'>
			<p class='uppercase tracking-widest text-sm md:text-base font-semibold text-teal-200'>
				JAMStack Web, Reading, Berkshire
			</p>
			<h1 class='mt-3 text-3xl md:text-5xl font-bold leading-tight'>
				Helping your business find the greatest outcomes through web technology
			</h1>
			<p class='mt-4 text-base md:text-lg leading-relaxed text-white/90'>
				At HeadForCode, we develop solutions that help businesses like yours reach the outcomes you
				set out to achieve
			</p>
			<a
				href='/contact'
				class='inline-block mt-6 bg-yellow-400 hover:bg-yellow-300 text-stone-950 font-semibold px-6 py-3 rounded-lg transition-colors'
			>
				Get in contact today
			</a>
		</div>
	</section>

	<!-- <TitlePage title={siteConfig.title} /> -->

	<!-- <div class='my-8 space-y-6'>
		<section class='rounded-2xl bg-teal-50 dark:bg-teal-900/30 p-6 md:p-8'>
			<p class='text-lg md:text-xl font-medium leading-relaxed text-teal-900 dark:text-white'>
				We help small businesses grow with smart, modern technology.
			</p>
			<p class='mt-3 text-base leading-relaxed text-teal-800 dark:text-teal-100'>
				From <strong>AI-powered solutions</strong> that streamline your operations, to <strong
					>content management systems</strong
				> that put you in control of your online presence, to <strong
					>bespoke web development</strong
				> that turns visitors into customers &mdash; we deliver the tools your business needs to thrive
				in a digital world.
			</p>
			<p class='mt-3 text-sm text-teal-600 dark:text-teal-200'>
				Explore our latest thinking below, or get in touch to see how we can help.
			</p>
		</section>
	</div> -->

	<ListCategories />

	<div>
		<h2 class='text-lg font-medium tracking-wide text-end'>Latest Posts</h2>
		<ListPosts FirstBig={true} posts={posts} />
	</div>
	<ButtondownSubscription />
</BaseLayout>

<script>
	import { animate } from 'motion'
	const showAnimations = localStorage.getItem('animations') === 'true'

	if (showAnimations) {
		animate(
			'.title',
			{ y: [80, 0], opacity: [0, 1] },
			{
				duration: 2.5,
				opacity: { duration: 3 },

				offset: [0, 0.55, 0.75]
			}
		)
	}
</script>
